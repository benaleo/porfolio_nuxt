# Pooled connection (runtime) — serverless-safe (e.g. Neon pooler)
DATABASE_URL="postgresql://user:password@HOST-pooler.REGION.aws.neon.tech/db?sslmode=require"

# Direct (non-pooled) connection for migrations
DIRECT_DATABASE_URL="postgresql://user:password@HOST.REGION.aws.neon.tech/db?sslmode=require"

# Admin credentials for CMS login
ADMIN_USERNAME="yourusername"
ADMIN_PASSWORD="yourpassword"

# JWT secret for signing session tokens
JWT_SECRET="replace-with-a-strong-random-secret"

# Optional site URL
SITE_URL="http://localhost:3000"

# Contact form (existing)
FORMSPREE_ENDPOINT=""

# Cloudflare Storage
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_REGION=auto
R2_BUCKET=your_bucket_name
# Optional: If you set a custom/public domain for the bucket, put it here, e.g. https://cdn.example.com
# If left empty, we'll derive a default public URL pattern
R2_PUBLIC_BASE_URL=https://file.yourdomain.com

APP_SECRET=xxx